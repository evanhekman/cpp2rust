{
  "name": "max_two",
  "params": [
    {
      "name": "a",
      "type": "i32"
    },
    {
      "name": "b",
      "type": "i32"
    }
  ],
  "return_type": "i32",
  "example_rust": "pub fn max_two(a: i32, b: i32) -> i32 { if (a > b) { return a; } else { return b; } }",
  "test_cases": [
    {
