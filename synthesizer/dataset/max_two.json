        "1",
        "2"
      ],
      "expected_output": "2"
    },
    {
      "inputs": [
        "3",
        "3"
      ],
      "expected_output": "3"
    },
    {
      "inputs": [
        "5",
        "2"
      ],
      "expected_output": "5"
    },
    {
      "inputs": [
        "-1",
        "0"
      ],
      "expected_output": "0"
    },
    {
      "inputs": [
        "0",
        "-1"
      ],
      "expected_output": "0"
    },
    {
      "inputs": [
        "7",
        "4"
      ],
      "expected_output": "7"
    }
  ]
